{
  "country_code": "AE",
  "country_name": "United Arab Emirates",
  "passport_rules": {
    "passport_number_regex": "^[A-Z0-9]{8,9}$",
    "required_fields": [
      "passport_number",
      "surname",
      "given_names",
      "nationality",
      "date_of_birth",
      "sex",
      "date_of_expiry"
    ],
    "date_format": "YYYY-MM-DD",
    "min_expiry_months_for_visa": 6
  },
  "visa_rules": {
    "supported_visa_types": ["tourist", "business", "transit"],
    "required_documents": ["passport_scan", "photo", "travel_itinerary"]
  }
}

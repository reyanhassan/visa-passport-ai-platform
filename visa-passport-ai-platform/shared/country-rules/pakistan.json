{
  "country_code": "PK",
  "country_name": "Pakistan",
  "passport_rules": {
    "passport_number_regex": "^[A-Z]{2}[0-9]{7}$",
    "required_fields": [
      "passport_number",
      "surname",
      "given_names",
      "nationality",
      "date_of_birth",
      "sex",
      "date_of_expiry"
    ],
    "date_format": "YYYY-MM-DD",
    "min_expiry_months_for_visa": 6
  },
  "visa_rules": {
    "supported_visa_types": ["tourist", "business", "family_visit"],
    "required_documents": ["passport_scan", "photo", "bank_statement"]
  }
}

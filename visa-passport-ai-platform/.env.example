# Host connections
DATABASE_URL=postgresql://visa_user:visa_password@localhost:5432/visa_platform
REDIS_URL=redis://localhost:6379
OCR_SERVICE_URL=http://localhost:8001
OCR_PROVIDER=mock
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-idDocument
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Container-to-container connections
DOCKER_DATABASE_URL=postgresql://visa_user:visa_password@postgres:5432/visa_platform
DOCKER_REDIS_URL=redis://redis:6379
DOCKER_OCR_SERVICE_URL=http://ocr-service:8001

# Web application
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=change_this_to_a_secure_secret
FIELD_ENCRYPTION_KEY=change_this_32_byte_key

# Deployment modes (local defaults preserve Docker, Redis, and worker behavior)
DEPLOYMENT_TARGET=local
EXTRACTION_MODE=queue

# Uploads
UPLOAD_PROVIDER=local
LOCAL_UPLOAD_DIR=uploads/private
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
SIGNED_URL_EXPIRES_SECONDS=900
MAX_UPLOAD_SIZE_MB=15

# Internal services
INTERNAL_API_KEY=local-internal-api-key-change-me
PASSPORT_EXTRACTION_QUEUE=passport-extraction
WORKER_CONCURRENCY=5
OCR_REQUEST_TIMEOUT_MS=30000
OCR_MAX_FILE_SIZE_MB=15
OCR_ALLOWED_ORIGINS=http://localhost:3000
ENVIRONMENT=development

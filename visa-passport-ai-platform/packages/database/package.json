{
  "name": "@visa-platform/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@visa-platform/config": "workspace:*",
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "prisma": "^6.19.0",
    "typescript": "catalog:"
  }
}
